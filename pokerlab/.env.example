# pokerlab — environment config.
# Copy this file to `.env` (same folder) and fill in real values. `.env` is gitignored.
# Only needed for the OPTIONAL LLM "coach's take" narrator — the game and the
# deterministic coach work fine without any of this.

# Your Anthropic API key (required to enable the narrator).
ANTHROPIC_API_KEY=sk-ant-...

# Model for the narration. Optional — this is the default (fast + cheap).
POKERLAB_NARRATOR_MODEL=claude-haiku-4-5-20251001
